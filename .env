# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_USER=dataflow
POSTGRES_PASSWORD=dataflow_secret_change_me
POSTGRES_DB=dataflow_db

# ── Backend ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dataflow:dataflow_secret_change_me@db:5432/dataflow_db

# ── Frontend ───────────────────────────────────────────────────────
# In development, Vite proxies /api to localhost:8000 (no change needed)
# In production Docker, nginx proxies to the backend service
VITE_API_URL=http://localhost:8000
